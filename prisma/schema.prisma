generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../data/scanzapp-prisma.db"
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String        @map("password_hash")
  role         Role          @default(user)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  sessions     Session[]
  profile      Profile?
  settings     UserSettings?
  meals        Meal[]
  waterLogs    WaterLog[]
  scanResults  ScanResult[]
  conversations Conversation[]
  messages      Message[]
  chatConsents  ChatConsent[]
  chatUsages    ChatUsage[]
  mealSuggestionCache MealSuggestionCache?
  savedMealSuggestions SavedMealSuggestion[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Profile {
  userId       String   @id @map("user_id")
  selectedGoal String?  @map("selected_goal")
  formJson     String   @default("{}") @map("form_json")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model UserSettings {
  userId       String   @id @map("user_id")
  settingsJson String   @map("settings_json")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Meal {
  id          String       @id
  userId      String       @map("user_id")
  name        String
  calories    Float
  protein     Float
  carbs       Float
  fat         Float
  time        String
  date        String
  source      MealSource
  confidence  Float?
  note        String?
  mealCategory MealCategory? @map("meal_category")
  imageUrl    String?      @map("image_url")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  scanResults ScanResult[]

  @@index([userId, date])
  @@map("meals")
}

model WaterLog {
  id        String   @id
  userId    String   @map("user_id")
  date      String
  time      String
  amount    Float
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("water_logs")
}

model ScanResult {
  id             String     @id @default(cuid())
  userId         String?    @map("user_id")
  mealId         String?    @map("meal_id")
  model          String
  status         ScanStatus
  isFood         Boolean?   @map("is_food")
  confidence     Float?
  latencyMs      Int        @map("latency_ms")
  upstreamStatus Int?       @map("upstream_status")
  errorMessage   String?    @map("error_message")
  rawPreview     String?    @map("raw_preview")
  createdAt      DateTime   @default(now()) @map("created_at")
  user           User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  meal           Meal?      @relation(fields: [mealId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("scan_results")
}

model MealSuggestionCache {
  userId          String   @id @map("user_id")
  suggestionsJson String   @map("suggestions_json")
  generatedAt     DateTime @map("generated_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("meal_suggestion_cache")
}

model SavedMealSuggestion {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  normalizedName String   @map("normalized_name")
  name           String
  calories       Float
  protein        Float
  carbs          Float
  fat            Float
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@index([userId, createdAt])
  @@map("saved_meal_suggestions")
}

model Conversation {
  id         String      @id @default(cuid())
  userId     String      @map("user_id")
  title      String
  summary    String?
  pinned     Boolean     @default(false)
  archivedAt DateTime?   @map("archived_at")
  deletedAt  DateTime?   @map("deleted_at")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   Message[]
  usages     ChatUsage[]

  @@index([userId, updatedAt])
  @@index([userId, archivedAt, updatedAt])
  @@index([userId, pinned, updatedAt])
  @@map("conversations")
}

model Message {
  id               String         @id @default(cuid())
  conversationId   String         @map("conversation_id")
  userId           String         @map("user_id")
  role             ChatRole
  content          String
  status           MessageStatus  @default(pending)
  parentMessageId  String?        @map("parent_message_id")
  clientRequestId  String?        @map("client_request_id")
  model            String?
  finishReason     String?        @map("finish_reason")
  inputTokens      Int?           @map("input_tokens")
  outputTokens     Int?           @map("output_tokens")
  estimatedCostUsd Float?         @map("estimated_cost_usd")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  conversation     Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentMessage    Message?       @relation("MessageRetryChain", fields: [parentMessageId], references: [id], onDelete: SetNull)
  retryMessages    Message[]      @relation("MessageRetryChain")
  usages           ChatUsage[]

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@unique([userId, clientRequestId])
  @@map("messages")
}

model ChatConsent {
  id            String            @id @default(cuid())
  userId        String            @map("user_id")
  scope         ChatConsentScope
  policyVersion String            @map("policy_version")
  grantedAt     DateTime          @default(now()) @map("granted_at")
  revokedAt     DateTime?         @map("revoked_at")
  uiVersion     String?           @map("ui_version")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scope, policyVersion, revokedAt])
  @@index([userId, scope, grantedAt])
  @@map("chat_consents")
}

model ChatUsage {
  id               String           @id @default(cuid())
  userId           String           @map("user_id")
  conversationId   String           @map("conversation_id")
  messageId        String?          @map("message_id")
  requestId        String?          @map("request_id")
  model            String
  outcome          ChatUsageOutcome
  latencyMs        Int?             @map("latency_ms")
  inputTokens      Int?             @map("input_tokens")
  outputTokens     Int?             @map("output_tokens")
  estimatedCostUsd Float?           @map("estimated_cost_usd")
  createdAt        DateTime         @default(now()) @map("created_at")
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation     Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message          Message?         @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([conversationId, createdAt])
  @@index([requestId])
  @@map("chat_usages")
}

enum Role {
  user
  admin
}

enum MealSource {
  scan
  manual
}

enum MealCategory {
  breakfast
  lunch
  dinner
  snack
  special
}

enum ScanStatus {
  success
  error
}

enum ChatRole {
  user
  assistant
}

enum MessageStatus {
  pending
  streaming
  complete
  stopped
  error
}

enum ChatConsentScope {
  ai_chat_basic
  profile_context
  nutrition_history
  hydration_history
  image_analysis
  memory
}

enum ChatUsageOutcome {
  success
  stopped
  error
  timeout
}
